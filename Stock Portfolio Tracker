 stock_prices = {
    "AAPL": 180,
    "TSLA": 250,
    "GOOG": 140,
    "MSFT": 320
}

total = 0

print("📈 Stock Portfolio Tracker")

while True:
    stock = input("Enter Stock Name (or quit): ").upper()

    if stock == "QUIT":
        break

    if stock in stock_prices:
        qty = int(input("Enter Quantity: "))
        investment = stock_prices[stock] * qty
        total += investment

        print(f"{stock} Investment = ${investment}")
    else:
        print("Stock not found!")

print("\nTotal Portfolio Value = $", total)

with open("portfolio.txt", "w") as file:
    file.write(f"Total Portfolio Value = ${total}")

print("Portfolio saved to portfolio.txt")
